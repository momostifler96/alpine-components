{
  "name": "@momoledev/alpine-components",
  "version": "1.0.0",
  "description": "Composants Alpine.js réutilisables : Select, Dropdown, InputText, InputTags, Switch, Slider, Form, InputMask, Toast",
  "main": "dist/index.umd.js",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.umd.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "vite build --config vite.lib.config.js",
    "build:demo": "vite build",
    "preview": "vite preview",
    "deploy":"wrangler pages deploy dist --project-name=alpine-components",
    "prepublishOnly": "npm run build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "alpinejs",
    "alpine",
    "components",
    "select",
    "dropdown",
    "toast",
    "form",
    "input-mask",
    "switch",
    "slider",
    "frontend",
    "tailwindcss"
  ],
  "author": "Momoledev <momoledev2021@gmail.com>",
  "license": "MIT",
  "peerDependencies": {
    "alpinejs": "^3.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.0",
    "vitepress": "^1.6.4"
  }
}
